# Helios Pro — Environment Variables
# Copy this file to `.env.local` (local dev) or set these in your Vercel project settings.

# === REQUIRED for production auth ===
# Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-32-char-random-secret"

# Public URL of your deployed app (no trailing slash)
# Local dev:  http://localhost:3000
# Vercel:     https://your-project.vercel.app
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === Database (PostgreSQL recommended for Vercel — use Neon, Supabase, or Vercel Postgres) ===
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/helios_pro?sslmode=require"

# === Optional: Google OAuth (for social login) ===
# Leave blank to disable social login.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Demo mode ===
# If the above are NOT set, Helios Pro runs in demo mode (no DB, no auth).
# All 137 pages render with mock data — perfect for previewing the UI kit.
